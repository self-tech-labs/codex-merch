{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "sourceUrl", "checkedAt", "positioning", "pillars", "visualRules"],
  "properties": {
    "$schema": {"type": "string"},
    "name": {"type": "string", "minLength": 1},
    "sourceUrl": {"type": "string", "format": "uri"},
    "checkedAt": {"type": "string", "format": "date"},
    "positioning": {"type": "string", "minLength": 20},
    "pillars": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "visualRules": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
