{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Merch Product",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "slug",
      "title",
      "workflow",
      "meme",
      "commerce",
      "production",
      "providerRefs",
      "signals",
      "assets",
      "prompts"
    ],
    "properties": {
      "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
      "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
      "aliases": {
        "type": "array",
        "uniqueItems": true,
        "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
      },
      "title": {"type": "string", "minLength": 1},
      "workflow": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "enum": ["draft", "generated", "mockups_ready", "approved", "published", "archived"]
          },
          "updatedAt": {"type": "string", "format": "date-time"},
          "lastError": {"type": ["string", "null"]}
        }
      },
      "category": {"type": "string"},
      "description": {"type": "string"},
      "productDetails": {
        "type": "object",
        "required": ["materials", "care", "origin", "productionTime", "mockupNotice"],
        "properties": {
          "materials": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "fabricWeight": {"type": "string", "minLength": 1},
          "fit": {"type": "string", "minLength": 1},
          "construction": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "care": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "origin": {"type": "string", "minLength": 1},
          "productionTime": {"type": "string", "minLength": 1},
          "mockupNotice": {"type": "string", "minLength": 1},
          "sizeGuide": {
            "type": "object",
            "required": ["unit", "tolerance", "rows"],
            "properties": {
              "unit": {"type": "string", "minLength": 1},
              "tolerance": {"type": "string", "minLength": 1},
              "rows": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["size", "length", "width", "sleeve"],
                  "properties": {
                    "size": {"type": "string", "minLength": 1},
                    "length": {"type": "string", "minLength": 1},
                    "width": {"type": "string", "minLength": 1},
                    "sleeve": {"type": "string", "minLength": 1}
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "meme": {
        "type": "object",
        "required": ["source", "brief", "rightsNote"],
        "properties": {
          "source": {"type": "string", "minLength": 1},
          "brief": {"type": "string", "minLength": 1},
          "rightsNote": {"type": "string", "minLength": 20}
        }
      },
      "signals": {
        "type": "object",
        "required": ["profile", "queries", "sources"],
        "properties": {
          "profile": {"type": "string"},
          "queries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["provider", "query"],
              "properties": {
                "provider": {"enum": ["x"]},
                "query": {"type": "string"},
                "maxResults": {"type": "integer", "minimum": 10, "maximum": 100}
              }
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["provider"],
              "properties": {
                "provider": {"enum": ["x"]}
              },
              "additionalProperties": true
            }
          }
        }
      },
      "commerce": {
        "type": "object",
        "required": ["handle", "unitAmount", "currency", "tags", "variants"],
        "properties": {
          "handle": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "unitAmount": {"type": "integer", "minimum": 1},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "variants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "sku", "color", "size", "providerVariantId", "availableForSale", "selectedOptions"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "sku": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
                "color": {"type": "string", "minLength": 1},
                "size": {"type": "string", "minLength": 1},
                "providerVariantId": {"type": "integer", "minimum": 1},
                "availableForSale": {"type": "boolean"},
                "selectedOptions": {"type": "array"}
              }
            }
          }
        }
      },
      "production": {
        "type": "object",
        "required": ["provider", "baseProduct", "technique", "placements"],
        "properties": {
          "provider": {"enum": ["printful"]},
          "baseProduct": {"type": "string", "minLength": 1},
          "technique": {
            "enum": [
              "DTG",
              "DTFlex",
              "Embroidery",
              "Sublimation",
              "All-Over Cotton",
              "All-Over Synthetic",
              "Knitting"
            ]
          },
          "textLayer": {"type": "string"},
          "placements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["area", "file"],
              "properties": {
                "area": {"type": "string", "minLength": 1},
                "file": {"type": "string", "pattern": "^assets/"},
                "text": {"type": "string"},
                "url": {"type": "string"},
                "width": {"type": "integer", "minimum": 1},
                "height": {"type": "integer", "minimum": 1},
                "position": {"type": "object"}
              }
            }
          }
        }
      },
      "providerRefs": {
        "type": "object",
        "properties": {
          "printful": {
            "type": "object",
            "required": ["productId", "variants"],
            "properties": {
              "productId": {"type": ["integer", "null"], "minimum": 1},
              "mockupTaskKey": {"type": ["string", "null"]},
              "mockupTaskFailures": {"type": "integer", "minimum": 0},
              "lastFailedMockupTaskKey": {"type": ["string", "null"]},
              "variants": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["variantId", "catalogVariantId", "syncVariantId", "available"],
                  "properties": {
                    "variantId": {"type": "string", "minLength": 1},
                    "catalogVariantId": {"type": "integer", "minimum": 1},
                    "syncVariantId": {"type": "integer", "minimum": 1},
                    "available": {"type": "boolean"}
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "additionalProperties": true
      },
      "assets": {
        "type": "object",
        "required": ["artwork", "mockups"],
        "properties": {
          "artwork": {"type": "string", "pattern": "^assets/"},
          "printFiles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["placement", "path"],
              "properties": {
                "placement": {"type": "string"},
                "path": {"type": "string", "pattern": "^assets/"},
                "url": {"type": "string"}
              }
            }
          },
          "customerPhotos": {"type": "array", "items": {"type": "string", "pattern": "^assets/"}},
          "mockups": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^assets/"}}
        }
      },
      "approval": {
        "type": "object",
        "properties": {
          "approvedAt": {"type": ["string", "null"], "format": "date-time"},
          "approvedBy": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        }
      },
      "prompts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
    }
  }
}
