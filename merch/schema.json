{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Merch Product",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "slug",
      "title",
      "status",
      "workflow",
      "meme",
      "commerce",
      "production",
      "providerRefs",
      "signals",
      "assets",
      "prompts"
    ],
    "properties": {
      "id": {"type": "string"},
      "slug": {"type": "string"},
      "title": {"type": "string"},
      "status": {
        "enum": ["draft", "generated", "mockups_ready", "approved", "published", "archived"]
      },
      "workflow": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "enum": ["draft", "generated", "mockups_ready", "approved", "published", "archived"]
          },
          "updatedAt": {"type": "string"},
          "lastError": {"type": ["string", "null"]}
        }
      },
      "category": {"type": "string"},
      "description": {"type": "string"},
      "meme": {
        "type": "object",
        "required": ["source", "brief", "rightsNote"],
        "properties": {
          "source": {"type": "string"},
          "brief": {"type": "string"},
          "rightsNote": {"type": "string"}
        }
      },
      "signals": {
        "type": "object",
        "required": ["profile", "queries", "sources"],
        "properties": {
          "profile": {"type": "string"},
          "queries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["provider", "query"],
              "properties": {
                "provider": {"type": "string"},
                "query": {"type": "string"},
                "maxResults": {"type": "number"}
              }
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["provider"],
              "properties": {
                "provider": {"type": "string"}
              },
              "additionalProperties": true
            }
          }
        }
      },
      "commerce": {
        "type": "object",
        "required": ["handle", "price", "currency", "tags", "variants"],
        "properties": {
          "handle": {"type": "string"},
          "price": {"type": "string"},
          "currency": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "sku", "color", "size", "providerVariantId", "selectedOptions"],
              "properties": {
                "id": {"type": "string"},
                "sku": {"type": "string"},
                "color": {"type": "string"},
                "size": {"type": "string"},
                "providerVariantId": {"type": "number"},
                "availableForSale": {"type": "boolean"},
                "selectedOptions": {"type": "array"}
              }
            }
          }
        }
      },
      "production": {
        "type": "object",
        "required": ["provider", "baseProduct", "technique", "placements"],
        "properties": {
          "provider": {"type": "string"},
          "baseProduct": {"type": ["string", "null"]},
          "technique": {
            "enum": [
              "DTG",
              "DTFlex",
              "Embroidery",
              "Sublimation",
              "All-Over Cotton",
              "All-Over Synthetic",
              "Knitting"
            ]
          },
          "textLayer": {"type": "string"},
          "placements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["area", "file"],
              "properties": {
                "area": {"type": "string"},
                "file": {"type": "string"},
                "text": {"type": "string"},
                "url": {"type": "string"},
                "width": {"type": "number"},
                "height": {"type": "number"},
                "position": {"type": "object"}
              }
            }
          }
        }
      },
      "providerRefs": {
        "type": "object",
        "properties": {
          "printful": {
            "type": "object",
            "required": ["productId", "variantIds"],
            "properties": {
              "productId": {"type": ["number", "string", "null"]},
              "mockupTaskKey": {"type": ["string", "null"]},
              "variantIds": {"type": "array", "items": {"type": "number"}}
            }
          }
        },
        "additionalProperties": true
      },
      "assets": {
        "type": "object",
        "required": ["artwork", "mockups"],
        "properties": {
          "artwork": {"type": "string"},
          "printFiles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["placement", "path"],
              "properties": {
                "placement": {"type": "string"},
                "path": {"type": "string"},
                "url": {"type": "string"}
              }
            }
          },
          "customerPhotos": {"type": "array", "items": {"type": "string"}},
          "mockups": {"type": "array", "items": {"type": "string"}}
        }
      },
      "approval": {
        "type": "object",
        "properties": {
          "approvedAt": {"type": ["string", "null"]},
          "approvedBy": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        }
      },
      "prompts": {"type": "array", "items": {"type": "string"}}
    }
  }
}
