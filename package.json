{
  "name": "codex-merch",
  "private": true,
  "sideEffects": false,
  "version": "2026.4.2",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "vite preview",
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "node --import tsx --test 'scripts/*.test.mjs' 'app/**/*.test.ts'",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db.migrate.ts",
    "orders:inspect": "tsx scripts/orders.ts inspect",
    "orders:retry": "tsx scripts/orders.ts retry",
    "orders:reconcile": "tsx scripts/orders.ts reconcile",
    "codegen": "react-router typegen",
    "merch:new": "node scripts/merch.mjs new --aop",
    "merch:new:standard": "node scripts/merch.mjs new --standard",
    "merch:validate": "node scripts/merch.mjs validate",
    "merch:signals": "node scripts/merch.mjs signals",
    "merch:signals:x": "node scripts/merch.mjs signals:x",
    "merch:research:x": "node scripts/merch.mjs signals:x",
    "merch:art-director:review": "node scripts/merch.mjs art-director:review",
    "merch:generate-artwork": "node scripts/merch.mjs generate-artwork",
    "merch:compose-print-file": "node scripts/merch.mjs compose-print-file",
    "merch:compose-print-files": "node scripts/merch.mjs compose-print-files",
    "merch:catalog:mockups": "node scripts/merch.mjs catalog-mockups",
    "merch:mockups": "node scripts/merch.mjs mockups",
    "merch:photoshoot": "node scripts/merch.mjs photoshoot",
    "merch:fulfillment:verify": "node scripts/merch.mjs fulfillment:verify",
    "merch:printful:verify": "node scripts/merch.mjs printful:verify",
    "merch:printful:upsert": "node scripts/merch.mjs printful:upsert",
    "merch:fulfillment:order:dry-run": "node scripts/merch.mjs fulfillment:order:dry-run",
    "merch:printful:order:dry-run": "node scripts/merch.mjs printful:order:dry-run",
    "merch:publish": "node scripts/merch.mjs publish",
    "merch:weekly": "node scripts/weekly-merch.mjs prepare",
    "merch:trend-preview": "node scripts/owner-trend-preview.mjs",
    "merch:weekly:demo": "node scripts/weekly-merch.mjs prepare --fixture fixtures/x/codex-team-meme-30.synthetic.json --offline",
    "merch:weekly:release": "node scripts/weekly-merch.mjs release",
    "merch:weekly:status": "node scripts/weekly-merch.mjs status",
    "merch:weekly:evidence": "node scripts/weekly-evidence.mjs",
    "submission:verify:repository": "node scripts/submission-verify.mjs",
    "submission:verify": "npm run merch:validate && npm test && npm run typecheck && npm run lint && npm run build && npm run submission:verify:repository"
  },
  "dependencies": {
    "@react-router/node": "7.18.1",
    "@vercel/react-router": "1.3.1",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "drizzle-orm": "0.45.2",
    "inngest": "4.13.0",
    "isbot": "^5.1.22",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "7.18.1",
    "stripe": "22.3.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "1.61.1",
    "@react-router/dev": "7.18.1",
    "@react-router/fs-routes": "7.18.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/eslint": "^9.6.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.18.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "sharp": "^0.34.5",
    "tsx": "4.23.1",
    "typescript": "^5.9.2",
    "vite": "^8.0.1"
  },
  "overrides": {
    "@vercel/static-config@3.4.0": {
      "ajv": "8.20.0"
