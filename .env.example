PUBLIC_SITE_URL=http://localhost:5173
# Keep `preview` for Build Week. `production` only unlocks the first commerce
# gate; CHECKOUT_ENABLED and every provider/legal dependency must still pass.
STOREFRONT_MODE=preview
DATABASE_URL=
CHECKOUT_ENABLED=false
# Real purchases are a time-limited OpenAI Build Week jury pilot. Keep the
# public Preview free and accountless; share this code only in private judge
# testing instructions. Use at least 16 unpredictable characters.
JURY_SALES_ENABLED=false
JURY_ACCESS_CODE=
# Judging ends August 5, 2026 at 5:00 p.m. PDT (August 6 at 00:00 UTC).
JURY_SALES_END_AT=2026-08-06T00:00:00Z
MERCH_PILOT_APPROVED=false
# Separate post-pilot authority for publishing any additional sellable product.
MERCH_EXPANSION_APPROVED=false
STOREFRONT_LEGAL_APPROVED=false
STOREFRONT_TAX_SHIPPING_APPROVED=false
STOREFRONT_CONTACT_EMAIL=elliot@ritsl.com
# Must exactly match the reviewed, version-controlled policy bundle in
# app/lib/merchant-policy.ts.
STOREFRONT_POLICY_VERSION=2026-07-21

# Stripe Checkout
# Vercel Production requires an sk_live_ key. Use a separate sandbox key in
# branch-scoped staging and a different signing secret for each webhook endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Set an explicit, owner-approved pilot territory. Do not rely on code defaults.
STRIPE_ALLOWED_SHIPPING_COUNTRIES=CH,US
# Choose exactly one shipping configuration. Read-only CH and US estimates
# support the CHF 9.10 pilot charge; a live key requires a live shr_ ID if that
# path is used instead.
STRIPE_SHIPPING_RATE_ID=
STRIPE_FLAT_SHIPPING_AMOUNT=910
# Set true only after applicable registrations and Stripe Tax settings exist.
STRIPE_AUTOMATIC_TAX=false

# Printful API
# Use a single-store private token for a Manual order/API store with orders and
# sync_products read/write scopes. Keep drafts manual throughout the pilot.
PRINTFUL_TOKEN=
PRINTFUL_STORE_ID=
PRINTFUL_AUTO_CONFIRM=false
PRINTFUL_MAX_RETRIES=3
PRINTFUL_RETRY_BASE_MS=1000
PRINTFUL_TIMEOUT_MS=10000
PRINTFUL_ALLOW_NON_PUBLIC_ASSET_URLS=false

# X API
X_BEARER_TOKEN=
X_LIST_ID=2067819170989854863
X_API_TIMEOUT_MS=20000
X_API_MAX_RETRIES=2
X_API_RETRY_BASE_MS=1000

# Durable fulfillment
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_SERVE_ORIGIN=

# OpenAI Responses + Images APIs
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6
OPENAI_RESPONSES_TIMEOUT_MS=180000
OPENAI_RESPONSES_MAX_RETRIES=2
OPENAI_RESPONSES_RETRY_BASE_MS=1000

# Weekly automation: fail closed until an owner enables release
MERCH_WEEKLY_RELEASE_ENABLED=false
MERCH_WEEKLY_RUN_ROOT=.cache/merch-weekly
# Set `external` only when another system intentionally owns production deploys.
MERCH_DEPLOY_PROVIDER=vercel
MERCH_VERCEL_SCOPE=ritsl
MERCH_VERCEL_PROJECT_ID=prj_8EwSYjyvg6SFIJXIDpjHFt4A9Uop
VERCEL_TOKEN=
MERCH_VERCEL_API_TIMEOUT_MS=20000
MERCH_DEPLOY_TIMEOUT_MS=600000
MERCH_DEPLOY_POLL_MS=10000
MERCH_MOCKUP_POLL_ATTEMPTS=30
MERCH_MOCKUP_POLL_MS=10000
